---
import { getCollection } from "astro:content";
import Layout from "../../layout/JournalPost.astro";

// Generate statics paths for all entries in the journal collection
export async function getStaticPaths() {
    const journalEntries = await getCollection("journal");
    return journalEntries.map((entry) => ({
        params: { slug: entry.slug },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const formattedDate = entry.data.date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
});
---

<Layout
    title={entry.data.title}
    description={entry.data.description ?? "Journal entry."}
    ogType="article"
>
<p class="title-2">
    {entry.data.description}
</p>
    <article class="max-w-3xl prose-gruvbox">
        <header>
            <p class="text-gruv-gray font-mono text-sm m-0">
                <time datetime={entry.data.date.toISOString()}>{formattedDate}</time>
            </p>
        </header>

        <div class="prose prose-invert max-w-none">
            <Content />
        </div>
    </article>
</Layout>

<style is:global>
    @reference "../../styles/global.css";
    /* Basic minimal styling for the markdown output to fit Gruvbox */
    .prose-gruvbox {
        @apply text-gruv-fg leading-relaxed;
    }

    .prose-gruvbox h1,
    .prose-gruvbox h2,
    .prose-gruvbox h3,
    .prose-gruvbox h4 {
        @apply font-mono font-normal mt-8 mb-4;
    }

    .prose-gruvbox h1 {
        @apply text-2xl text-gruv-yellow-light;
    }
    .prose-gruvbox h2 {
        @apply text-xl text-gruv-blue-light;
    }
    .prose-gruvbox h3 {
        @apply text-lg text-gruv-purple-light;
    }

    .prose-gruvbox p {
        @apply mb-4;
    }

    .prose-gruvbox ul {
        @apply list-disc list-inside mb-4 pl-4;
    }

    .prose-gruvbox ol {
        @apply list-decimal list-inside mb-4 pl-4;
    }

    .prose-gruvbox pre {
        @apply bg-gruv-bg0-s p-4 rounded-md overflow-x-auto mb-4 border border-gruv-gray-light/20;
    }

    .prose-gruvbox code {
        @apply font-mono text-sm bg-gruv-bg0-s px-1.5 py-0.5 rounded text-gruv-aqua-light;
    }

    .prose-gruvbox pre code {
        @apply bg-transparent p-0 text-inherit;
    }

    .prose-gruvbox blockquote {
        @apply border-l-4 border-gruv-gray-light bg-gruv-bg0-s py-2 pl-4 pr-2 mb-4 italic text-gruv-gray-light;
    }

    .prose-gruvbox blockquote p:last-child {
        @apply mb-0;
    }
</style>
