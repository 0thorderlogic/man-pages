---
import "../styles/global.css";
interface Props {
  title: string;
  description?: string;
  image?: string;
  ogType?: "website" | "article";
}

import { name, metaDescription } from "../../consts";
import MetaHead from "../components/ui/MetaHead.astro";
import Footer from "../components/ui/Footer.astro";
const { title, description, image = "/images/linkpreview.png", ogType = "website" } = Astro.props;
const pageTitle = `${name}'s ${title}`;
const pageDescription = description ?? metaDescription;
---

<html lang="en">
  <head>
    <MetaHead title={pageTitle} description={pageDescription} image={image} ogType={ogType} />
  </head>
  <body>
    <div class="mx-auto flex min-h-screen w-full max-w-5xl flex-col px-5">
      <header class="pt-6">
        <a href="/journal">back to journal</a>
        <h1 class="title-1 mt-2">{title}</h1>
      </header>
      <main class="">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
